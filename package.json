{
	"name": "obsidian-meeting-scribe-plugin",
	"version": "0.1.0",
	"description": "Record meetings, transcribe with cloud STT, summarize with LLM, and auto-generate structured meeting notes — all within Obsidian.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint src/",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:e2e": "wdio run ./wdio.conf.mts",
		"test:integration": "vitest run --config vitest.integration.config.ts"
	},
	"keywords": [],
	"license": "MIT",
	"devDependencies": {
		"@eslint/js": "9.30.1",
		"@types/mocha": "^10.0.10",
		"@types/node": "^22.0.0",
		"@wdio/cli": "^9.26.1",
		"@wdio/local-runner": "^9.26.1",
		"@wdio/mocha-framework": "^9.26.1",
		"@wdio/spec-reporter": "^9.26.1",
		"esbuild": "0.25.5",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "14.0.0",
		"jiti": "2.6.1",
		"jsdom": "^28.1.0",
		"tslib": "2.4.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.35.1",
		"vitest": "^3.1.0",
		"wdio-obsidian-reporter": "^2.4.0",
		"wdio-obsidian-service": "^2.4.0"
	},
	"dependencies": {
		"obsidian": "latest"
	}
}
